{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "env PYTHONPATH=\"${CLAUDE_PLUGIN_ROOT}/src\" python3 -m grask.cli shim --root \"${CLAUDE_PLUGIN_ROOT}\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "env PYTHONPATH=\"${CLAUDE_PLUGIN_ROOT}/src\" python3 -m grask.hook"
          }
        ]
      }
    ]
  }
}
